# =============================================================================
# STRIPE — cole só a chave abaixo e rode: pnpm stripe:setup
# Dashboard: https://dashboard.stripe.com/test/apikeys
# =============================================================================

STRIPE_SECRET_KEY=

# URL do admin em produção (webhook criado automaticamente pelo stripe:setup)
STRIPE_WEBHOOK_URL=https://approf-admin.vercel.app

# Preenchidos automaticamente após pnpm stripe:setup — não edite manualmente
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_SEMIANNUAL=
STRIPE_PRICE_ANNUAL=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# Desenvolvimento local (admin Next.js — porta 3002)
# Se já usa Supabase/OpenAI na Vercel, pode copiar os mesmos valores aqui.
# =============================================================================

NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_COORDINATOR_PUBLIC_URL=https://approf.com.br
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PROFESSORA_APP_URL=http://localhost:3001

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
REPORT_SHARE_SECRET=

RESEND_API_KEY=
RESEND_FROM_EMAIL=Approf <noreply@approf.com.br>

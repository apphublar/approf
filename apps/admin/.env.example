# Super Admin
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

# Preencher quando a conta Supabase estiver validada.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Deve ser usado apenas em server-side code, nunca exposto ao navegador.
SUPABASE_SERVICE_ROLE_KEY=
# Segredo usado para assinar links publicos de documentos compartilhados.
REPORT_SHARE_SECRET=

# IA server-side
ANTHROPIC_API_KEY=
# Modelo padrao (fallback das etapas e valor inicial se nada mais estiver definido)
ANTHROPIC_TEXT_MODEL=claude-sonnet-4-20250514
# Opcional: um modelo por etapa do pipeline textual (rascunho / revisao BNCC / refinamento)
ANTHROPIC_DRAFT_MODEL=
ANTHROPIC_REVIEW_MODEL=
ANTHROPIC_REFINE_MODEL=

# Imagens server-side (portfolio visual)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=high
# Custo estimado por imagem em centavos (usado em logs/cotas)
OPENAI_IMAGE_COST_CENTS=120

# Base publica do app da professora, usada futuramente para callbacks/links.
NEXT_PUBLIC_PROFESSORA_APP_URL=http://localhost:3001

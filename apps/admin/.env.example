# Super Admin
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
# URL publica usada nos convites da coordenadora. Em producao, use o dominio que hospeda /coordenadora/[token].
NEXT_PUBLIC_COORDINATOR_PUBLIC_URL=https://admin.approf.com.br
# URL publica do site institucional (termos, privacidade, marketing).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Preencher quando a conta Supabase estiver validada.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Deve ser usado apenas em server-side code, nunca exposto ao navegador.
SUPABASE_SERVICE_ROLE_KEY=
# Segredo usado para assinar links publicos de documentos compartilhados.
REPORT_SHARE_SECRET=

# IA server-side
OPENAI_API_KEY=
# Cambio usado para converter custos USD (provedores) em BRL.
AI_USD_TO_BRL=5.5
# Meta mensal por professora (em centavos BRL) para controle de saldo/cota.
AI_MONTHLY_INCLUDED_COST_CENTS=800
AI_MONTHLY_COST_LIMIT_CENTS=1000
# Modelos explicitos por etapa/tipo de documento.
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_DRAFT_MODEL=gpt-4o-mini
OPENAI_REVIEW_MODEL=gpt-4o
OPENAI_HUMANIZE_MODEL=gpt-5

# Imagens server-side (portfolio visual)
OPENAI_INTERVENTIONS_MODEL=gpt-4o-mini
OPENAI_MATERIAL_REVIEW_MODEL=gpt-4o-mini
MATERIAL_AI_CONFIDENCE_THRESHOLD=0.82
# Preco oficial por 1M de tokens para GPT textual usado em Intervencoes.
OPENAI_TEXT_INPUT_COST_PER_MILLION_USD=0.15
OPENAI_TEXT_OUTPUT_COST_PER_MILLION_USD=0.6
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_STANDALONE_IMAGE_MODEL=gpt-image-1-mini
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=high
OPENAI_STANDALONE_IMAGE_QUALITY=medium
OPENAI_STANDALONE_IMAGE_ESTIMATED_COST_CENTS=110
OPENAI_STANDALONE_IMAGE_COST_CENTS=60
OPENAI_STANDALONE_IMAGE_INPUT_COST_PER_MILLION_USD=2
OPENAI_STANDALONE_IMAGE_OUTPUT_COST_PER_MILLION_USD=8
# Custo estimado por imagem em centavos (usado em logs/cotas)
OPENAI_IMAGE_COST_CENTS=120
OPENAI_IMAGE_ESTIMATED_COST_CENTS=80
# Preco oficial por 1M de tokens para gpt-image-2 (imagem).
OPENAI_IMAGE_INPUT_COST_PER_MILLION_USD=8
OPENAI_IMAGE_OUTPUT_COST_PER_MILLION_USD=30

# Transcricao de audio server-side (Nova anotacao)
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# Custo estimado para 30 segundos de audio (o backend calcula proporcional por duracao)
OPENAI_TRANSCRIPTION_COST_CENTS_30S=2
# Preco oficial por minuto da transcricao GPT-4o mini.
OPENAI_TRANSCRIPTION_USD_PER_MINUTE=0.003

# Base publica do app da professora, usada futuramente para callbacks/links.
NEXT_PUBLIC_PROFESSORA_APP_URL=http://localhost:3001

# E-mail transacional (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Approf <noreply@approf.com.br>

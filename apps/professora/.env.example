# App PWA das professoras
# Use `mock` para desenvolvimento visual local.
# Use `supabase` quando o projeto Supabase estiver criado e as chaves abaixo preenchidas.
VITE_APPROF_DATA_MODE=mock

# Supabase > Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL publica do projeto Vercel `approf-admin`, sem barra no final.
# Exemplo: https://approf-admin.vercel.app
VITE_APPROF_ADMIN_API_URL=

# Futuro: endpoint de sync offline quando o backend estiver ativo.
VITE_APPROF_SYNC_ENABLED=false
